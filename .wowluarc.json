{
    "diagnostics": {
        "enable": [
            "need-check-nil",
            "nil-index",
            "invalid-op",
            "redundant-or",
            "redundant-and",
            "redundant-condition"
        ]
    },
    "globals": {
        "read": [
            "TSMDEV"
        ]
    },
    "ignore": [
        "Docs/",
        "Tests/"
    ],
    "framexml": false
}
